# Скопируйте этот файл в .env и заполните своими значениями.
# Никогда не добавляйте .env в git!

# Путь к JSON-ключу service account Google (скачать в Google Cloud Console)
GOOGLE_CREDS_FILE=credentials/service_account.json

# ID Google Таблицы — берётся из URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Имя листа внутри таблицы (по умолчанию Sheet1)
WORKSHEET_NAME=Sheet1
